+      cycles+=4;
+    }
+    break;
+  case 0xD1:  /* cmp_zpindy, AM_ZPINDY,  "CMP"  */
+    {
+      UChar temp = zpindy_operand(reg_pc+1);
+      reg_p = CLEAR_NTZC | SET_CTST(reg_a < temp) | flnz_list[(UChar)(reg_a-temp)];
+      reg_pc+=2;
+      cycles+=7;
+    }
+    break;
+  case 0xD2:  /* cmp_zpind,  AM_ZPIND,   "CMP"  */
+    {
